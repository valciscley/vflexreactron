{
  "name": "vflexreactron",
  "version": "1.0.0",
  "description": "Aplicativo Reactron",
  "main": "electron.js",
  "scripts": {
    "start": "webpack serve --hot --open --mode development",
    "startsemopen": "webpack serve --hot --mode development",
    "prestart": "if exist \"prod\" (rmdir prod /s /q)",
    "prod": "webpack --config webpack.config.js --mode production",
    "preprod": "if exist \"prod\" (rmdir prod /s /q)",
    "electron": "concurrently \"npm run startsemopen\" \"wait-on http://localhost:8080 && electron .\"",
    "dist": "npm run prod",
    "predist": "if exist \"dist\" (rmdir dist /s /q)",
    "postdist": "electron-builder --ia32 --x64",
    "dist32": "npm run prod",
    "predist32": "if exist \"dist\" (rmdir dist /s /q)",
    "postdist32": "electron-builder --ia32",
    "dist64": "npm run prod",
    "predist64": "if exist \"dist\" (rmdir dist /s /q)",
    "postdist64": "electron-builder --x64"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@babel/core": "^7.13.10",
    "@babel/preset-env": "^7.13.10",
    "@babel/preset-react": "^7.12.13",
    "babel-loader": "^8.2.2",
    "concurrently": "^6.0.0",
    "copy-webpack-plugin": "^8.0.0",
    "css-loader": "^5.1.1",
    "electron": "^12.0.0",
    "electron-builder": "^22.10.5",
    "file-loader": "^6.2.0",
    "html-webpack-plugin": "^5.3.1",
    "react": "^17.0.1",
    "react-dom": "^17.0.1",
    "style-loader": "^2.0.0",
    "terser-webpack-plugin": "^5.1.1",
    "wait-on": "^5.2.1",
    "webpack": "^5.24.4",
    "webpack-cli": "^4.5.0",
    "webpack-dev-server": "^3.11.2"
  },
  "dependencies": {
    "electron-is-dev": "^2.0.0"
  },
  "build": {
    "nsis":{
      "oneClick": false
    },
    "win":{
      "icon": "publico/app.ico"
    },
    "appId": "reactron",
    "files": [
      "prod/**/*",
      "node_modules/**/*",
      "./electron.js"
    ]
  }
}
